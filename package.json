{
  "name": "nuxt-paper",
  "version": "1.0.0",
  "description": "A port of the AstroPaper blog theme to Nuxt 4 and Nuxt Content",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "oxlint --deny-warnings",
    "lint:fix": "oxlint --fix",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:nuxt": "vitest run --project nuxt",
    "test:coverage": "vitest run --coverage",
    "test:browser": "pnpm generate && playwright test",
    "test:browser:prebuilt": "playwright test",
    "start:e2e:webserver": "serve .output/public -l 5678 --no-clipboard"
  },
  "dependencies": {
    "@nuxt/content": "^3.6.3",
    "@nuxt/fonts": "^0.14.0",
    "@shikijs/transformers": "^4.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@takumi-rs/core": "^1.8.1",
    "better-sqlite3": "^12.2.0",
    "dayjs": "^1.11.13",
    "katex": "^0.17.0",
    "minisearch": "^7.1.2",
    "nuxt": "^4.0.3",
    "nuxt-og-image": "^6.5.3",
    "rehype-callouts": "^2.1.2",
    "rehype-katex": "^7.0.1",
    "remark-collapse": "^0.1.2",
    "remark-math": "^6.0.0",
    "remark-toc": "^9.0.0",
    "tailwindcss": "^4.3.0",
    "ufo": "^1.6.4"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.60.0",
    "@unhead/vue": "2.1.15",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.2",
    "oxlint": "^1.69.0",
    "serve": "^14.2.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.4"
  }
}
