{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["unicorn", "typescript", "oxc", "vue", "import", "vitest"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "env": {
    "browser": true,
    "node": true
  },
  "rules": {
    "no-console": "warn",
    "typescript/consistent-type-imports": "error"
  },
  "overrides": [
    {
      "files": ["scripts/**"],
      "rules": {
        "no-console": "off"
      }
    }
  ],
  "ignorePatterns": [
    "dist/**",
    ".output/**",
    ".nuxt/**",
    "node_modules/**",
    "coverage/**",
    "content/**"
  ]
}
